[
  {
    "name": "/setstake validates amount",
    "steps": [
      {
        "send": { "text": "/setstake 0" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Usage: /setstake <amount>. Amount must be at least 1."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/setstake reports missing persistent storage",
    "steps": [
      {
        "send": { "text": "/setstake 25" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Stake storage is not configured. Set DATABASE_URL before setting stakes."
            }
          }
        ]
      }
    ]
  }
]
