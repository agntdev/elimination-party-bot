[
  {
    "name": "Join window expiry auto-starts the round on next group message",
    "steps": [
      {
        "send": { "callback": "e2e:autostart-seed" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "Auto-start fixture ready." } }
        ]
      },
      {
        "send": { "callback": "join:round", "userId": 101, "username": "101" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "Joined the round. Stake: 10 points. Players joined: 1." } }
        ]
      },
      {
        "send": { "callback": "join:round", "userId": 202, "username": "202" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "Joined the round. Stake: 10 points. Players joined: 2. Join window: 30s." } }
        ]
      },
      {
        "send": { "callback": "e2e:autostart-expire" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "Join window expired." } }
        ]
      },
      {
        "send": { "text": "hey", "chatId": 1, "userId": 101 },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Round started. Players joined: 2." } },
          { "method": "sendAnimation", "payload": { "animation": "https://example.test/countdown-3.gif", "caption": "3" } },
          { "method": "sendAnimation", "payload": { "animation": "https://example.test/countdown-2.gif", "caption": "2" } },
          { "method": "sendAnimation", "payload": { "animation": "https://example.test/countdown-1.gif", "caption": "1" } },
          { "method": "sendMessage", "payload": { "text": "Eliminated player: 202.\nPayouts: 101 +10." } }
        ]
      },
      {
        "send": { "callback": "e2e:autostart-reset" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "Auto-start fixture cleared." } }
        ]
      }
    ]
  },
  {
    "name": "No auto-start when join window has not expired",
    "steps": [
      {
        "send": { "callback": "e2e:autostart-seed" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "Auto-start fixture ready." } }
        ]
      },
      {
        "send": { "callback": "join:round", "userId": 101, "username": "101" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "Joined the round. Stake: 10 points. Players joined: 1." } }
        ]
      },
      {
        "send": { "callback": "join:round", "userId": 202, "username": "202" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "Joined the round. Stake: 10 points. Players joined: 2. Join window: 30s." } }
        ]
      },
      {
        "send": { "text": "hello", "chatId": 1, "userId": 101 },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Sorry, I didn't understand that. Try /help." } }
        ]
      },
      {
        "send": { "callback": "e2e:autostart-reset" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "Auto-start fixture cleared." } }
        ]
      }
    ]
  }
]