[
  {
    "name": "Run Round Now reports missing persistent storage",
    "steps": [
      {
        "send": { "callback": "start:round" },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Round storage is not configured. Set REDIS_URL before starting rounds."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Run Round Now bypasses join window and starts the round immediately",
    "steps": [
      {
        "send": { "callback": "e2e:seed" },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": { "text": "E2E round fixture ready." }
          }
        ]
      },
      {
        "send": { "callback": "join:round", "userId": 101 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Joined the round. Stake: 10 points. Players joined: 1."
            }
          }
        ]
      },
      {
        "send": { "callback": "join:round", "userId": 202 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Joined the round. Stake: 10 points. Players joined: 2. Join window: 30s."
            }
          }
        ]
      },
      {
        "send": { "callback": "start:round", "userId": 101 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": { "text": "Round started. Players joined: 2." }
          },
          {
            "method": "sendAnimation",
            "payload": {
              "animation": "https://example.test/countdown-3.gif",
              "caption": "3"
            }
          },
          {
            "method": "sendAnimation",
            "payload": {
              "animation": "https://example.test/countdown-2.gif",
              "caption": "2"
            }
          },
          {
            "method": "sendAnimation",
            "payload": {
              "animation": "https://example.test/countdown-1.gif",
              "caption": "1"
            }
          },
          {
            "method": "sendMessage",
            "payload": {
              "text": "Eliminated player: 202.\nPayouts: 101 +10."
            }
          }
        ]
      },
      {
        "send": { "callback": "e2e:reset" },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": { "text": "E2E round fixture cleared." }
          }
        ]
      }
    ]
  }
]